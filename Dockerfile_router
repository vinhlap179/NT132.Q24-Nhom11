# Dockerfile for Router
FROM ubuntu:22.04

# Install required packages
RUN apt-get update && \
    apt-get install -y iproute2 iputils-ping net-tools curl gnupg tcpdump

# Add GPG key for FRR
RUN curl -s https://deb.frrouting.org/frr/keys.gpg | tee /usr/share/keyrings/frrouting.gpg > /dev/null

# Set FRR version and distribution codename manually
ARG FRRVER="frr-stable"
RUN echo "deb [signed-by=/usr/share/keyrings/frrouting.gpg] https://deb.frrouting.org/frr jammy $FRRVER" \
    | tee -a /etc/apt/sources.list.d/frr.list

# Update package list and install FRR
RUN apt-get update && \
    apt-get install -y frr frr-pythontools

# Ensure daemons are configured to start
RUN sed -i 's/^zebra=.*/zebra=yes/' /etc/frr/daemons && \
    sed -i 's/^ripd=.*/ripd=yes/' /etc/frr/daemons && \
    sed -i 's/^ospfd=.*/ospfd=yes/' /etc/frr/daemons && \
    sed -i 's/^vtysh_enable=.*/vtysh_enable=yes/' /etc/frr/daemons

RUN echo "[service]" > /etc/frr/frr.conf && \
    echo "ospf-instance" >> /etc/frr/frr.conf

# Check if vtysh is installed and accessible
RUN ls /usr/bin/vtysh || ls /usr/sbin/vtysh

# Start FRR service on container start
CMD /usr/lib/frr/frrinit.sh start && tail -f /dev/null

